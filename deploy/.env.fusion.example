# octo-doc — FUSION deployment env template (OCT-135)
#
# Copy to deploy/.env.fusion and edit the values marked REQUIRED. Every knob is
# read at boot; changing a value requires a restart.
#
# Use with:
#   docker compose \
#     --env-file deploy/.env.fusion \
#     -f deploy/docker-compose.yml \
#     -f deploy/docker-compose.fusion.yml \
#     up -d
#
# Vars in this file layer on top of .env / .env.example — only fusion-specific
# and production-override knobs live here; storage limits, rate limits, etc.
# stay in .env.example.
#
# ══════════════════════════════════════════════════════════════════════════════
# Fusion identity bridge (OCT-135)
# ══════════════════════════════════════════════════════════════════════════════

# LOGIN_ENABLED — REQUIRED for fusion (default: false)
#   Since OCT-145 方案 C the reverse proxy (octo-server docs_proxy) is the sole
#   login provider — this switch only controls the overlay UI's login
#   affordance (/auth/me.authConfigured). Fusion deploy behind docs_proxy:
#   set to true. Stand-alone deploy (no proxy): leave false — overlay stays
#   anonymous. The identity middleware itself is always on; a wrong value
#   here cannot lock the admin out.
LOGIN_ENABLED=true

# OCTO_OPENAPI_URL / OCTO_USERINFO_URL — REMOVED (deprecated by OCT-145 方案 C)
#   doc no longer calls octo openapi. Identity is passed as internal trust
#   headers (X-Octo-Uid/Name/Role) by the reverse proxy after its own auth
#   pass. Delete any surviving OCTO_OPENAPI_URL / OCTO_USERINFO_URL / userinfo
#   TTL knobs from your env files — they have no effect.

# OWNER — optional (default: empty = reuse octo superAdmin)
#   Comma-separated octo logins to promote to CapAuthor. Per OCT-130 the
#   fusion default is EMPTY — octo superAdmin sessions bypass OWNER via role
#   in internal/service/auth.go, so leaving this empty is the intended
#   behavior. Only set it to grant CapAuthor to specific non-superAdmin
#   logins.
# OWNER=

# FRAME_ANCESTORS — REQUIRED for octo-web iframe embed (default: 'none' = blocked)
#   CSP frame-ancestors value. If octo-web is going to iframe rendered docs
#   in its panel, this MUST list the panel's origin, or the browser refuses
#   the embed with a CSP error and the panel stays blank. Wrap origins in
#   single quotes only if they include reserved CSP keywords.
FRAME_ANCESTORS="'self' https://web.octo.example.com"

# ══════════════════════════════════════════════════════════════════════════════
# Auth toggles (production defaults)
# ══════════════════════════════════════════════════════════════════════════════

# ALLOW_BOOTSTRAP — must be false in production (default in fusion overlay: false)
#   Enables `GET /v1/admin/bootstrap` which mints the first write token when
#   no WRITE_TOKEN is set. Fusion services sit on the public internet — an
#   open bootstrap is a first-token-grab race. Only flip to true for a single
#   restart, mint the token, then flip back to false and redeploy.
ALLOW_BOOTSTRAP=false

# WRITE_TOKEN — production alternative to bootstrap
#   If set, this is THE Bearer token for every write endpoint. Prefer setting
#   this from a real secret store instead of relying on bootstrap.
# WRITE_TOKEN=

# COOKIE_SECURE — leave true behind TLS (default: true)
COOKIE_SECURE=true

# ══════════════════════════════════════════════════════════════════════════════
# Dedicated PostgreSQL (octodoc-pg, per OCT-130: doc gets its own PG)
# ══════════════════════════════════════════════════════════════════════════════

PG_USER=octodoc
PG_PASSWORD=change-me-please
PG_DB=octodoc_fusion
# Host port for the dedicated PG. Default 5433 to avoid clashing with any
# other PG already on 5432 on the host.
PG_HOST_PORT=5433

# ══════════════════════════════════════════════════════════════════════════════
# S3 / MinIO (fusion may reuse existing octo MinIO or run its own bucket)
# ══════════════════════════════════════════════════════════════════════════════

S3_BUCKET=octo-doc-fusion
S3_REGION=us-east-1
# S3_ENDPOINT — leave unset to use MinIO service from the base compose; set an
# external URL to plug into an existing octo MinIO or AWS S3.
# S3_ENDPOINT=https://s3.octo.example.com
# S3_FORCE_PATH_STYLE=1
S3_ACCESS_KEY_ID=CHANGE_ME_S3_ACCESS_KEY_ID
S3_SECRET_ACCESS_KEY=change-me

# ══════════════════════════════════════════════════════════════════════════════
# Public URL / TLS front-end
# ══════════════════════════════════════════════════════════════════════════════

BASE_URL=https://docs.octo.example.com
DOMAIN=docs.octo.example.com

# LOG_LEVEL — debug|info|warn|error|silent
LOG_LEVEL=info
