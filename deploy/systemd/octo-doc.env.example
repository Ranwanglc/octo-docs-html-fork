# /etc/octo-doc/octo-doc.env — systemd EnvironmentFile for octo-doc (fusion, OCT-135)
#
# Install location: /etc/octo-doc/octo-doc.env (referenced by
# /etc/systemd/system/octo-doc.service). Owned root:octodoc, mode 0640 —
# never world-readable; contains write token + PG password.
#
# 所有 CHANGE_ME_* 必须部署前替换。字面串明显不像密码，避免被误当"脱敏输出"照抄进生产。

# ─── Networking ──────────────────────────────────────────────────────────────
PORT=8080
HOST=0.0.0.0
BASE_URL=https://docs.octo.example.com

# ─── Fusion identity bridge (OCT-135, OCT-145 方案 C) ───────────────────────
# 方案 C 后 doc 只信 octo-server 反代注入的 X-Octo-Uid/Name/Role —— 不再拉 userinfo，
# 因此 OCTO_OPENAPI_URL / OCTO_USERINFO_URL 已废弃，不在此文件中列。
# LOGIN_ENABLED 只控 overlay 的登录 UI 亲和性：fusion 部署置 true（反代在前），
# stand-alone 置 false（overlay 匿名）。
LOGIN_ENABLED=true
# OWNER 默认留空 (OCT-130: 复用 octo superAdmin via role)。
# OWNER=

# ─── Storage ─────────────────────────────────────────────────────────────────
# 独立 PG (OCT-130: octo-doc 走自己的 PG 实例)。
# 完整形式：postgres://<user>:***@<host>:<port>/<db>?<opts>
DATABASE_URL=postgres://octodoc:CHANGE_ME_PG_PASSWORD@127.0.0.1:5432/octodoc_fusion?sslmode=disable
PG_POOL_MAX=10

S3_BUCKET=octo-doc-fusion
S3_REGION=us-east-1
S3_ENDPOINT=https://s3.octo.example.com
# S3_FORCE_PATH_STYLE=1
S3_ACCESS_KEY_ID=CHANGE_ME_S3_ACCESS_KEY_ID
S3_SECRET_ACCESS_KEY=CHANGE_ME_S3_SECRET_ACCESS_KEY

# ─── Write auth (production-safe defaults) ───────────────────────────────────
ALLOW_BOOTSTRAP=false
# 生产建议：先 bootstrap 一次拿到 token，然后配到密钥仓，作为 WRITE_TOKEN 注入。
# WRITE_TOKEN=CHANGE_ME_INJECT_FROM_SECRETS_STORE

# ─── CSP / cookies ───────────────────────────────────────────────────────────
FRAME_ANCESTORS="'self' https://web.octo.example.com"
COOKIE_SECURE=true

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
