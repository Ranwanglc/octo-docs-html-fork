# octo-docs-html — deployment env (MySQL, terminal auth = author-is-creator)
#
# 这份清单以本机跑通的 doc-app-test 容器为 ground truth，搭配 deploy/Dockerfile
# 使用。复制成 .env 后填写标 [必配] 的值即可；所有键在启动时读取，改值需重启。
#
#   docker build -f deploy/Dockerfile -t octo-docs-html:local .
#   docker run --env-file deploy/.env  -p 8080:8080  octo-docs-html:local
#
# ⚠️ 只配 Dockerfile 不给 env 会用代码默认值——默认是 PostgreSQL + 关闭一堆功能，
#    在本环境（MySQL + iframe + 侧栏登记 + 内联图片）会静默丢功能。见每项 [注]。

# ══════════════════════════════════════════════════════════════════════════════
# 应用镜像 —— [可选]，默认从本仓库源码构建
# ══════════════════════════════════════════════════════════════════════════════

# compose 的 app/migrate 默认 image=octo-docs-html:local；本地无此 tag 时
# `docker compose up --build` 会用 deploy/Dockerfile 从本仓库源码构建（源码支持
# MySQL）。旧的 ghcr.io/mininglamp-oss/octo-docs-html:latest 早于 MySQL 支持、会无视
# STORAGE_DRIVER 硬连 postgres，故不再默认。等发布了含 MySQL 的镜像，设此变量
# 覆盖即可 pull 而不构建。
# APP_IMAGE=octo-docs-html:local

# ══════════════════════════════════════════════════════════════════════════════
# 存储：数据库（MySQL）—— [必配]，代码默认是 postgres，不配直接连错库
# ══════════════════════════════════════════════════════════════════════════════

# [必配] 驱动。代码默认 "postgres"；本环境跑 MySQL 必须显式设 mysql。
STORAGE_DRIVER=mysql

# ── 两种 MySQL 用法，二选一 ────────────────────────────────────────────────
# 用法 A（推荐·全新环境一键起）：叠加 deploy/docker-compose.mysql.yml，compose
#   自带 MySQL 容器。这时只填下面 MYSQL_* 即可，DATABASE_URL 会由 overlay 自动
#   指向 bundled mysql 容器，本文件里的 DATABASE_URL 会被忽略。
MYSQL_DATABASE=octo_docs
MYSQL_USER=octo_docs
MYSQL_PASSWORD=CHANGE_ME_DB_PW
MYSQL_ROOT_PASSWORD=CHANGE_ME_DB_ROOT_PW
#
# 用法 B（接已有外部 MySQL·手工 docker run 或不叠 overlay）：填 DATABASE_URL 指向
#   你的 MySQL。go-sql-driver 格式（不是 postgres:// URL）。
DATABASE_URL=octo_docs:CHANGE_ME_DB_PW@tcp(mysql:3306)/octo_docs?charset=utf8mb4&parseTime=true&loc=Local

# ══════════════════════════════════════════════════════════════════════════════
# 存储：S3 / MinIO —— [必配]，blob 正文/资产都落这里
# ══════════════════════════════════════════════════════════════════════════════

S3_BUCKET=octo-doc
S3_REGION=us-east-1
# [必配] MinIO 地址；用 AWS S3 时填其 endpoint。
S3_ENDPOINT=http://minio:9000
# [必配 for MinIO] 代码默认 false；MinIO 必须开 path-style，否则 bucket 寻址失败。
S3_FORCE_PATH_STYLE=1
# [必配]
S3_ACCESS_KEY_ID=CHANGE_ME_S3_KEY
S3_SECRET_ACCESS_KEY=CHANGE_ME_S3_SECRET

# ══════════════════════════════════════════════════════════════════════════════
# 鉴权 / 身份桥（终态：砍反代，doc 直调 server verify；author = 创建者）
# ══════════════════════════════════════════════════════════════════════════════

# [必配] 身份桥总开关。默认 false = 登录静默回落、overlay 匿名。
LOGIN_ENABLED=true
# [必配] octo-server origin。doc 直调其 /v1/auth/verify(-bot) 做身份校验。
#   空 ⇒ 只剩 share-code 只读，用户/bot 登录全失效。
OCTO_SERVER_BASE_URL=http://octo-server:8090
# [必配] bot 令牌鉴权开关。默认 false，不开则 bot 写接口无法鉴权。
#   注：开启还依赖上面的 OCTO_SERVER_BASE_URL 才有 verify 提供者。
BOT_AUTH_ENABLED=true

# ── 生产安全默认（保持原样即可）──────────────────────────────────────────────
# [必配 false] 代码默认 true(!)。true 会开放 /v1/admin/bootstrap 抢首个写令牌，
#   公网必须 false。仅临时铸令牌时短暂开一下再关。
ALLOW_BOOTSTRAP=false
# TLS 后保持 true。
COOKIE_SECURE=true
# 可选：把指定非 superAdmin 的 octo 登录提升为 CapAuthor；留空 = 只信 superAdmin。
# OWNER=

# ══════════════════════════════════════════════════════════════════════════════
# 内联资产签名 —— [必配]，缺了 HTML 里的图片全部 404
# ══════════════════════════════════════════════════════════════════════════════

# [必配] 给内联 <img>/asset URL 签 HMAC 的密钥。浏览器原生子资源加载带不了 token 头，
#   渲染时靠这个短时签名放行。空 ⇒ 回退 WRITE_TOKEN；终态 WRITE_TOKEN 也不配 ⇒ 签名
#   key 为空 ⇒ 所有内联图片鉴权恒失败、图片挂掉。这是 doc 服务端密钥，前端不需要配。
ASSET_SIGNING_SECRET=CHANGE_ME_ASSET_SIGN_SECRET

# ══════════════════════════════════════════════════════════════════════════════
# iframe 嵌入 —— [必配]，octo-web 面板要 iframe 渲染页
# ══════════════════════════════════════════════════════════════════════════════

# [必配] CSP frame-ancestors。默认 'none' = 一切 iframe 被浏览器拒、面板空白。
#   同时也是 postMessage 发送方白名单（裸 http(s) origin 才生效，'self'/'none' 会被丢）。
#   多个 origin 空格分隔。生产填 web 面板的公网 origin。
FRAME_ANCESTORS=http://localhost:3000 http://localhost:3003 http://localhost:3001

# ══════════════════════════════════════════════════════════════════════════════
# docs-backend 侧栏登记 —— 发布的 HTML 要出现在 web 文档侧栏就 [必配]
# ══════════════════════════════════════════════════════════════════════════════

# 发布 HTML 后向 docs-backend 登记，使其出现在 web 侧栏文档列表。
#   空 ⇒ 功能禁用（不报错，但发布的文档不进侧栏）——即老板问的“可选但缺了丢功能”。
DOCS_BACKEND_REGISTER_URL=http://docs-backend:3000/v1/bot/docs
# 配套 bot Bearer 令牌，登记与绑定查询共用；never logged。URL 配了这个也要配。
DOCS_BACKEND_REGISTER_TOKEN=CHANGE_ME_BACKEND_BOT_TOKEN

# ══════════════════════════════════════════════════════════════════════════════
# doc_binding 通道（FEAT-3，按 slug 精确授权）—— 需要就配
# ══════════════════════════════════════════════════════════════════════════════

# octo-server 的 doc_binding 查询 origin（GET /v1/docs/bindings/:slug）。
#   空 ⇒ 通道关闭，回落到 trust-header 身份 + share-code 语义。
OCTO_DOC_BINDING_URL=http://octo-server:8090

# ══════════════════════════════════════════════════════════════════════════════
# 评论事件回投 IM（OCT-137/B webhook）—— 要评论推 IM 才配，成对
# ══════════════════════════════════════════════════════════════════════════════

# octo-server 评论事件 webhook 端点。空 ⇒ 关闭；评论不触发 IM 推送。
# OCTO_WEBHOOK_URL=http://octo-server:8090/v1/doc-webhook/comments
# 配套共享密钥（X-Octo-Doc-Webhook-Token）。URL 配了却缺它 ⇒ server 每次 503。
# OCTO_DOC_EVENT_WEBHOOK_TOKEN=CHANGE_ME_WEBHOOK_TOKEN

# ══════════════════════════════════════════════════════════════════════════════
# 公网 URL / 网络 / 日志（可选，按环境覆盖）
# ══════════════════════════════════════════════════════════════════════════════

# 渲染绝对链接前缀；空则用相对路径。生产填公网地址。
# BASE_URL=https://docs.octo.example.com
# 反代前置且可信时才开，否则客户端可伪造 X-Forwarded-For 绕限流。
# TRUST_PROXY_HEADERS=false
# 写接口 CORS 允许来源（逗号分隔）；空 = 仅同源。
# CORS_ORIGINS=
# debug|info|warn|error|silent
LOG_LEVEL=info

# 监听（Dockerfile 已内置默认，一般不用改）
# PORT=8080
# HOST=0.0.0.0
